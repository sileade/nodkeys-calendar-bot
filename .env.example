# ═══════════════════════════════════════════════════
# Nodkeys Calendar & Life Bot v5.0 — Environment
# ═══════════════════════════════════════════════════

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-chat-id

# Multiple allowed chat IDs (optional, comma-separated)
# Includes TELEGRAM_CHAT_ID automatically. Add group chat IDs here.
# ALLOWED_CHAT_IDS=-1001234567890,-1009876543210

# Per-user routing in group chats (optional)
# Format: username_or_id:display_name:calendar_rule|...
# calendar_rule: "family" (always family), "work" (always work), "auto" (Claude decides)
# Example: bot routes Vera's messages to family calendar, Ilea's by Claude analysis
# GROUP_USERS=vera_username:Вера:family|seleadi:Ilea:auto

# Proxy for Telegram API (optional, for restricted regions)
# TELEGRAM_PROXY_URL=socks5://ss-proxy:1080
# Custom Telegram API base URL (optional, to bypass DNS blocks)
# TELEGRAM_BASE_URL=https://149.154.167.220/bot

# ── Claude AI ──
CLAUDE_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-20250514
# Proxy for Claude API (optional)
# CLAUDE_PROXY_URL=socks5://ss-proxy:1080

# ── iCloud CalDAV (Calendar + Notes) ──
ICLOUD_USERNAME=your-icloud-email@icloud.com
ICLOUD_PASSWORD=your-icloud-app-specific-password
CALDAV_URL=https://caldav.icloud.com/

# ── Timezone ──
TZ=Europe/Moscow

# ── Calendar Names (as they appear in iCloud) ──
CALENDAR_FAMILY=Family
CALENDAR_WORK=Work
CALENDAR_REMINDERS=Reminders

# ── Kindle Configuration ──
KINDLE_EMAIL=your-kindle@kindle.com
KINDLE_EMAIL_FROM=your-sender@example.com
KINDLE_EMAIL_PASSWORD=your-email-app-specific-password
KINDLE_SMTP_HOST=smtp.mail.me.com
KINDLE_SMTP_PORT=587
# Fallback: if KINDLE_EMAIL_PASSWORD is empty, uses SMTP_PASSWORD then ICLOUD_PASSWORD
# SMTP_PASSWORD=

# Multi-device Kindle (optional, pipe-separated)
# KINDLE_DEVICES="My Kindle:email1@kindle.com|Family Kindle:email2@kindle.com"

# Kindle file storage paths (optional, defaults shown)
# KINDLE_TMP_DIR=/tmp/kindle_files
# KINDLE_BOOKS_STORAGE=/app/data/books
# KINDLE_BOOKS_DB=/app/data/books_history.json

# ── OpenAI API (optional, for AI format detection) ──
# OPENAI_API_KEY=your-openai-api-key

# ── Flibusta Book Search (optional) ──
# FLIBUSTA_BASE_URL=https://flibusta.is
# FLIBUSTA_PROXY_URL=socks5://ss-proxy:1080

# ── GitHub Repos (optional, for /repos health endpoint) ──
# GITHUB_TOKEN=ghp_your_github_personal_access_token
